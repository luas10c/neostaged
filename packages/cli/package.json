{
  "name": "neostaged",
  "version": "0.0.1",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "neostaged": "dist/cli.js"
  },
  "scripts": {
    "postinstall": "node ./postinstall.js",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "tsc-alias -f -p tsconfig.build.json",
    "lint": "eslint --cache",
    "test": "jest --passWithNoTests --verbose",
    "test:ci": "jest --passWithNoTests --ci",
    "test:watch": "jest --passWithNoTests --watch",
    "test:watchAll": "jest --passWithNoTests --watchAll",
    "test:coverage": "jest --passWithNoTests --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@swc/jest": "^0.2.39",
    "@types/node": "^25.6.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "optionalDependencies": {
    "@neostaged/neostaged-darwin-arm64": "0.0.1",
    "@neostaged/neostaged-darwin-x64": "0.0.1",
    "@neostaged/neostaged-linux-arm-gnueabihf": "0.0.1",
    "@neostaged/neostaged-linux-arm64-gnu": "0.0.1",
    "@neostaged/neostaged-linux-arm64-musl": "0.0.1",
    "@neostaged/neostaged-linux-ppc64-gnu": "0.0.1",
    "@neostaged/neostaged-linux-s390x-gnu": "0.0.1",
    "@neostaged/neostaged-linux-x64-gnu": "0.0.1",
    "@neostaged/neostaged-linux-x64-musl": "0.0.1",
    "@neostaged/neostaged-win32-arm64-msvc": "0.0.1",
    "@neostaged/neostaged-win32-ia32-msvc": "0.0.1",
    "@neostaged/neostaged-win32-x64-msvc": "0.0.1"
  },
  "repository": {
    "type": "git",
    "url": "git+http://github.com/luas10c/neostaged.git",
    "directory": "packages/core"
  },
  "bugs": {
